# Database (Railway provides DATABASE_URL automatically when you add PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shopping_lists

# Server port (Railway sets this automatically)
PORT=3001

# CORS origin (set to your client URL in production, e.g. https://your-client.up.railway.app)
# Leave empty for same-origin (local dev with proxy)
CORS_ORIGIN=
